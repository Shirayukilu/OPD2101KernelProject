	fragment@4 {
		target = <0xffffffff>;

		__overlay__ {
			#address-cells = <0x2>;
			#size-cells = <0x0>;
			interrupt-controller;
			#interrupt-cells = <0x4>;

			qcom,pm8150l@4 {
				compatible = "qcom,spmi-pmic";
				reg = <0x4 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;

				qcom,revid@100 {
					compatible = "qcom,qpnp-revid";
					reg = <0x100 0x100>;
					phandle = <0x1b>;
				};

				qcom,power-on@800 {
					compatible = "qcom,qpnp-power-on";
					reg = <0x800 0x100>;
				};

				qcom,temp-alarm@2400 {
					compatible = "qcom,spmi-temp-alarm";
					reg = <0x2400 0x100>;
					interrupts = <0x4 0x24 0x0 0x3>;
					io-channels = <0x1a 0x6>;
					io-channel-names = "thermal";
					#thermal-sensor-cells = <0x0>;
					qcom,temperature-threshold-set = <0x1>;
					phandle = <0x1d>;
				};

				clock-controller@5b00 {
					compatible = "qcom,spmi-clkdiv";
					reg = <0x5b00 0x100>;
					#clock-cells = <0x1>;
					qcom,num-clkdivs = <0x1>;
					clock-output-names = "pm8150l_div_clk1";
					clocks = <0xffffffff 0x0>;
					clock-names = "xo";
					phandle = <0xad>;
				};

				pinctrl@c000 {
					compatible = "qcom,spmi-gpio";
					reg = <0xc000 0xc00>;
					interrupts = <0x4 0xc0 0x0 0x0 0x4 0xc2 0x0 0x0 0x4 0xc3 0x0 0x0 0x4 0xc4 0x0 0x0 0x4 0xc5 0x0 0x0 0x4 0xc6 0x0 0x0 0x4 0xc7 0x0 0x0 0x4 0xc8 0x0 0x0 0x4 0xc9 0x0 0x0 0x4 0xca 0x0 0x0>;
					interrupt-names = "pm8150l_gpio1", "pm8150l_gpio3", "pm8150l_gpio4", "pm8150l_gpio5", "pm8150l_gpio6", "pm8150l_gpio7", "pm8150l_gpio8", "pm8150l_gpio9", "pm8150l_gpio10", "pm8150l_gpio11";
					gpio-controller;
					#gpio-cells = <0x2>;
					qcom,gpios-disallowed = <0x2 0xc>;
					phandle = <0x79>;

					colorctrl_enable_fade_default {

						enable_fade_default {
							pins = "gpio9";
							function = "normal";
							bias-disable;
							power-source = <0x0>;
							output-low;
							qcom,drive-strength = <0x3>;
							drive-push-pull;
							phandle = <0x7c>;
						};
					};

					colorctrl_enable_vm_default {

						enable_vm_default {
							pins = "gpio9";
							function = "normal";
							bias-disable;
							power-source = <0x0>;
							output-low;
							qcom,drive-strength = <0x3>;
							drive-push-pull;
							phandle = <0xae>;
						};
					};

					colorctrl_si_in_1_default {

						si_in_1_default {
							pins = "gpio8";
							function = "normal";
							bias-disable;
							power-source = <0x0>;
							output-low;
							qcom,drive-strength = <0x3>;
							drive-push-pull;
							phandle = <0x7e>;
						};
					};

					colorctrl_si_in_2_default {

						si_in_2_default {
							pins = "gpio11";
							function = "normal";
							bias-disable;
							power-source = <0x0>;
							output-low;
							qcom,drive-strength = <0x3>;
							drive-push-pull;
							phandle = <0x7f>;
						};
					};

					colorctrl_adc {

						colorctrl_adc_default {
							pins = "gpio7";
							function = "normal";
							bias-high-impedance;
							phandle = <0x82>;
						};
					};

					gpio5_adc {

						gpio5_adc_default {
							pins = "gpio5";
							function = "normal";
							bias-high-impedance;
							phandle = <0xf>;
						};
					};
				};

				vadc@3100 {
					compatible = "qcom,spmi-adc5";
					reg = <0x3100 0x100>;
					#address-cells = <0x1>;
					#size-cells = <0x0>;
					interrupts = <0x4 0x31 0x0 0x1>;
					interrupt-names = "eoc-int-en-set";
					qcom,adc-vdd-reference = <0x753>;
					#io-channel-cells = <0x1>;
					io-channel-ranges;
					phandle = <0x1a>;

					ref_gnd@0 {
						reg = <0x0>;
						label = "ref_gnd";
						qcom,pre-scaling = <0x1 0x1>;
					};

					vref_1p25@1 {
						reg = <0x1>;
						label = "vref_1p25";
						qcom,pre-scaling = <0x1 0x1>;
					};

					die_temp@2 {
						reg = <0x6>;
						label = "die_temp";
						qcom,pre-scaling = <0x1 0x1>;
					};

					board_id {
						reg = <0x12>;
						label = "board_id_vdata";
						qcom,ratiometric;
						qcom,pre-scaling = <0x1 0x1>;
					};

					vph_pwr@83 {
						reg = <0x83>;
						label = "vph_pwr";
						qcom,pre-scaling = <0x1 0x3>;
					};

					4g_5g_pa_therm@4d {
						reg = <0x4d>;
						label = "4g-5g-pa-therm-usr";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					skin_msm_therm@4e {
						reg = <0x4e>;
						label = "skin_msm_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					pa_therm2@4f {
						reg = <0x4f>;
						label = "pa_therm2";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					colorctrl_voltage_adc {
						reg = <0x94>;
						label = "colorctrl_voltage_adc";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,avg-samples = <0x2>;
						qcom,pre-scaling = <0x1 0x3>;
					};
				};

				bcl@3d00 {
					compatible = "qcom,bcl-v5";
					reg = <0x3d00 0x100>;
					interrupts = <0x4 0x3d 0x0 0x0 0x4 0x3d 0x1 0x0 0x4 0x3d 0x2 0x0>;
					interrupt-names = "bcl-lvl0", "bcl-lvl1", "bcl-lvl2";
					#thermal-sensor-cells = <0x1>;
					phandle = <0x1e>;
				};

				adc_tm@3500 {
					compatible = "qcom,adc-tm5";
					reg = <0x3500 0x100>;
					interrupts = <0x4 0x35 0x0 0x1>;
					interrupt-names = "thr-int-en";
					#address-cells = <0x1>;
					#size-cells = <0x0>;
					#thermal-sensor-cells = <0x1>;
					io-channels = <0x1a 0x4d 0x1a 0x4e 0x1a 0x4f>;
					phandle = <0x8c>;

					4g_5g_pa_therm@4d {
						reg = <0x4d>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};

					skin_msm_therm@4e {
						reg = <0x4e>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};

					pa_therm2@4f {
						reg = <0x4f>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};
				};
			};

			qcom,pm8150l@5 {
				compatible = "qcom,spmi-pmic";
				reg = <0x5 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;

				qcom,lcdb@ec00 {
					compatible = "qcom,qpnp-lcdb-regulator";
					reg = <0xec00 0x100>;
					interrupts = <0x5 0xec 0x1 0x1>;
					interrupt-names = "sc-irq";
					qcom,pmic-revid = <0x1b>;
					qcom,voltage-step-ramp;
					status = "disabled";
					phandle = <0xaf>;

					ldo {
						label = "ldo";
						regulator-name = "lcdb_ldo";
						regulator-min-microvolt = <0x3d0900>;
						regulator-max-microvolt = <0x5b8d80>;
						phandle = <0xb0>;
					};

					ncp {
						label = "ncp";
						regulator-name = "lcdb_ncp";
						regulator-min-microvolt = <0x3d0900>;
						regulator-max-microvolt = <0x5b8d80>;
						phandle = <0xb1>;
					};

					bst {
						label = "bst";
						regulator-name = "lcdb_bst";
						regulator-min-microvolt = <0x47b760>;
						regulator-max-microvolt = <0x5fbfb8>;
						phandle = <0xb2>;
					};
				};

				qcom,leds@d300 {
					compatible = "qcom,qpnp-flash-led-v2";
					status = "okay";
					reg = <0xd300 0x100>;
					label = "flash";
					interrupts = <0x5 0xd3 0x0 0x1 0x5 0xd3 0x3 0x1 0x5 0xd3 0x4 0x1>;
					interrupt-names = "led-fault-irq", "all-ramp-down-done-irq", "all-ramp-up-done-irq";
					qcom,hdrm-auto-mode;
					qcom,short-circuit-det;
					qcom,open-circuit-det;
					qcom,vph-droop-det;
					qcom,thermal-derate-en;
					qcom,thermal-derate-current = <0xc8 0x1f4 0x3e8>;
					qcom,isc-delay = <0xc0>;
					qcom,pmic-revid = <0x1b>;
					phandle = <0xb3>;

					qcom,flash_0 {
						label = "flash";
