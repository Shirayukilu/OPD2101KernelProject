			qcom,pm8009@a {
				compatible = "qcom,spmi-pmic";
				reg = <0xa 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;

				qcom,revid@100 {
					compatible = "qcom,qpnp-revid";
