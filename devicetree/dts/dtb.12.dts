	fragment@40 {
		target = <0xffffffff>;

		__overlay__ {

			display_panel_avdd_default {
				phandle = <0xe2>;

				mux {
					pins = "gpio61";
					function = "gpio";
				};

				config {
					pins = "gpio61";
					drive-strength = <0x8>;
					bias-disable = <0x0>;
					output-high;
				};
			};
		};
	};

	fragment@41 {
		target = <0xffffffff>;

		__overlay__ {

			qcom,msm-ext-disp {
				compatible = "qcom,msm-ext-disp";
				phandle = <0x24>;

				qcom,msm-ext-disp-audio-codec-rx {
					compatible = "qcom,msm-ext-disp-audio-codec-rx";
					phandle = <0x4e>;
				};
			};

			dsi_panel_pwr_supply {
				#address-cells = <0x1>;
				#size-cells = <0x0>;
				phandle = <0x20>;

				qcom,panel-supply-entry@0 {
					reg = <0x0>;
					qcom,supply-name = "vddio";
					qcom,supply-min-voltage = <0x1b7740>;
					qcom,supply-max-voltage = <0x1b7740>;
					qcom,supply-enable-load = <0xf230>;
					qcom,supply-disable-load = <0x50>;
					qcom,supply-post-on-sleep = <0x0>;
				};

				qcom,panel-supply-entry@1 {
					reg = <0x1>;
					qcom,supply-name = "vdd";
					qcom,supply-min-voltage = <0x2dc6c0>;
					qcom,supply-max-voltage = <0x2dc6c0>;
					qcom,supply-enable-load = <0xd13a8>;
					qcom,supply-disable-load = <0x0>;
				};

				qcom,panel-supply-entry@2 {
					reg = <0x2>;
					qcom,supply-name = "vout";
					qcom,supply-min-voltage = <0x111700>;
					qcom,supply-max-voltage = <0x111700>;
					qcom,supply-enable-load = <0xf230>;
					qcom,supply-disable-load = <0x50>;
					qcom,supply-post-on-sleep = <0xc>;
					qcom,supply-pre-off-sleep = <0xc>;
				};
			};

			dsi_panel_pwr_supply_dvt {
				#address-cells = <0x1>;
				#size-cells = <0x0>;
				phandle = <0x21>;

				qcom,panel-supply-entry@0 {
					reg = <0x0>;
					qcom,supply-name = "vddio";
					qcom,supply-min-voltage = <0x1b7740>;
					qcom,supply-max-voltage = <0x1b7740>;
					qcom,supply-enable-load = <0xf230>;
					qcom,supply-disable-load = <0x50>;
					qcom,supply-post-on-sleep = <0x0>;
				};

				qcom,panel-supply-entry@1 {
					reg = <0x1>;
					qcom,supply-name = "vci";
					qcom,supply-min-voltage = <0x2de600>;
					qcom,supply-max-voltage = <0x2de600>;
					qcom,supply-enable-load = <0xd13a8>;
					qcom,supply-disable-load = <0x0>;
				};

				qcom,panel-supply-entry@2 {
					reg = <0x2>;
					qcom,supply-name = "vout";
					qcom,supply-min-voltage = <0x111700>;
					qcom,supply-max-voltage = <0x111700>;
					qcom,supply-enable-load = <0xf230>;
					qcom,supply-disable-load = <0x50>;
					qcom,supply-post-on-sleep = <0xc>;
					qcom,supply-pre-off-sleep = <0xc>;
				};
			};

			dsi_panel_pwr_supply_lab_ibb {
				#address-cells = <0x1>;
				#size-cells = <0x0>;
				phandle = <0xe3>;

				qcom,panel-supply-entry@0 {
					reg = <0x0>;
					qcom,supply-name = "vddio";
					qcom,supply-min-voltage = <0x1b7740>;
					qcom,supply-max-voltage = <0x1b7740>;
					qcom,supply-enable-load = <0xf230>;
					qcom,supply-disable-load = <0x50>;
					qcom,supply-post-on-sleep = <0x14>;
				};

				qcom,panel-supply-entry@1 {
					reg = <0x1>;
					qcom,supply-name = "lab";
					qcom,supply-min-voltage = <0x4630c0>;
					qcom,supply-max-voltage = <0x5b8d80>;
					qcom,supply-enable-load = <0x186a0>;
					qcom,supply-disable-load = <0x64>;
