				qcom,va-vdd-micb-voltage = <0x1b7740 0x1b7740>;
				qcom,va-vdd-micb-current = <0x2bc0>;
				qcom,va-dmic-sample-rate = <0x927c0>;
				qcom,va-clk-mux-select = <0x1>;
				qcom,va-island-mode-muxsel = <0x33a0000>;
				qcom,default-clk-id = <0x0>;
				phandle = <0x13a>;
			};
		};
	};

