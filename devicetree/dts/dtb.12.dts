				pinctrl@c000 {
					compatible = "qcom,spmi-gpio";
					reg = <0xc000 0x400>;
					interrupts = <0xa 0xc0 0x0 0x0 0xa 0xc1 0x0 0x0 0xa 0xc2 0x0 0x0 0xa 0xc3 0x0 0x0>;
					interrupt-names = "pm8009_gpio1", "pm8009_gpio2", "pm8009_gpio3", "pm8009_gpio4";
