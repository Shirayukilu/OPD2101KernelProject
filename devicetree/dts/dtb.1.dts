						qcom,wf-play-rate-us = <0x1a0b>;
						qcom,wf-brake-pattern = <0x0>;
						qcom,wf-repeat-count = <0x1>;
						qcom,wf-s-repeat-count = <0x1>;
						qcom,lra-auto-resonance-disable;
					};

					wf_4 {
						qcom,effect-id = <0x4>;
						qcom,wf-vmax-mv = <0xe10>;
						qcom,wf-pattern = <0x3e3e3e3e 0x3e3e3e3e>;
						qcom,wf-play-rate-us = <0x1a0b>;
						qcom,wf-brake-pattern = <0x0>;
						qcom,wf-repeat-count = <0x1>;
						qcom,wf-s-repeat-count = <0x1>;
						qcom,lra-auto-resonance-disable;
					};

					wf_5 {
						qcom,effect-id = <0x5>;
						qcom,wf-vmax-mv = <0xe10>;
						qcom,wf-pattern = <0x3e3e3e3e 0x3e3e3e3e>;
						qcom,wf-play-rate-us = <0x1a0b>;
						qcom,wf-brake-pattern = <0x0>;
						qcom,wf-repeat-count = <0x1>;
						qcom,wf-s-repeat-count = <0x1>;
						qcom,lra-auto-resonance-disable;
					};
				};
			};
		};
	};

	fragment@3 {
