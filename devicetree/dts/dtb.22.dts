	fragment@4 {
		target = <0xffffffff>;

		__overlay__ {
			#address-cells = <0x2>;
			#size-cells = <0x0>;
			interrupt-controller;
			#interrupt-cells = <0x4>;

			qcom,pm8150l@4 {
				compatible = "qcom,spmi-pmic";
				reg = <0x4 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;

				qcom,revid@100 {
					compatible = "qcom,qpnp-revid";
					reg = <0x100 0x100>;
					phandle = <0x23>;
				};

				qcom,power-on@800 {
					compatible = "qcom,qpnp-power-on";
					reg = <0x800 0x100>;
				};

				qcom,temp-alarm@2400 {
					compatible = "qcom,spmi-temp-alarm";
					reg = <0x2400 0x100>;
					interrupts = <0x4 0x24 0x0 0x3>;
					io-channels = <0x21 0x6>;
					io-channel-names = "thermal";
					#thermal-sensor-cells = <0x0>;
					qcom,temperature-threshold-set = <0x1>;
					phandle = <0x26>;
				};

				clock-controller@5b00 {
					compatible = "qcom,spmi-clkdiv";
					reg = <0x5b00 0x100>;
					#clock-cells = <0x1>;
					qcom,num-clkdivs = <0x1>;
					clock-output-names = "pm8150l_div_clk1";
					clocks = <0xffffffff 0x0>;
					clock-names = "xo";
					phandle = <0xb6>;
				};

				pinctrl@c000 {
					compatible = "qcom,spmi-gpio";
					reg = <0xc000 0xc00>;
					interrupts = <0x4 0xc0 0x0 0x0 0x4 0xc2 0x0 0x0 0x4 0xc3 0x0 0x0 0x4 0xc4 0x0 0x0 0x4 0xc5 0x0 0x0 0x4 0xc6 0x0 0x0 0x4 0xc7 0x0 0x0 0x4 0xc9 0x0 0x0 0x4 0xca 0x0 0x0>;
					interrupt-names = "pm8150l_gpio1", "pm8150l_gpio3", "pm8150l_gpio4", "pm8150l_gpio5", "pm8150l_gpio6", "pm8150l_gpio7", "pm8150l_gpio8", "pm8150l_gpio10", "pm8150l_gpio11";
					gpio-controller;
					#gpio-cells = <0x2>;
					qcom,gpios-disallowed = <0x2 0x9 0xc>;
					phandle = <0xa>;

					gpio5_adc {

						gpio5_adc_default {
							pins = "gpio5";
							function = "normal";
							bias-high-impedance;
							phandle = <0xf>;
						};
					};

					mps_otg_en_active {
						pins = "gpio3";
						function = "normal";
						bias-disable;
						power-source = <0x0>;
						output-high;
						qcom,drive-strength = <0x3>;
						phandle = <0x13>;
					};

					mps_otg_en_sleep {
						pins = "gpio3";
						function = "normal";
						bias-disable;
						power-source = <0x0>;
						output-low;
						qcom,drive-strength = <0x3>;
						phandle = <0x14>;
					};

					mps_otg_en_default {
						pins = "gpio3";
						function = "normal";
						bias-disable;
						power-source = <0x0>;
						output-low;
						qcom,drive-strength = <0x3>;
						phandle = <0x15>;
					};

					wrx_otg_en_active {
						pins = "gpio11";
						function = "normal";
						bias-disable;
						power-source = <0x1>;
						output-high;
						qcom,drive-strength = <0x3>;
						phandle = <0x99>;
					};

					wrx_otg_en_sleep {
						pins = "gpio11";
						function = "normal";
						bias-disable;
						power-source = <0x1>;
						output-low;
						qcom,drive-strength = <0x3>;
						phandle = <0x9a>;
					};

					wrx_otg_en_default {
						pins = "gpio11";
						function = "normal";
						bias-disable;
						power-source = <0x1>;
						input-enable;
						qcom,drive-strength = <0x3>;
						phandle = <0x9b>;
					};

					wrx_en_active {
						pins = "gpio8";
						function = "normal";
						bias-disable;
						power-source = <0x1>;
						output-high;
						qcom,drive-strength = <0x3>;
						phandle = <0x96>;
					};

					wrx_en_sleep {
						pins = "gpio8";
						function = "normal";
						bias-disable;
						power-source = <0x1>;
						output-low;
						qcom,drive-strength = <0x3>;
						phandle = <0x97>;
					};

					wrx_en_default {
						pins = "gpio8";
						function = "normal";
						bias-disable;
						power-source = <0x1>;
						input-enable;
						qcom,drive-strength = <0x3>;
						phandle = <0x98>;
					};

					gpio7D_adc {

						gpio7D_adc_default {
							pins = "gpio7";
							function = "normal";
							bias-high-impedance;
							bias-disable;
							phandle = <0x22>;
						};
					};
				};

				vadc@3100 {
					compatible = "qcom,spmi-adc5";
					reg = <0x3100 0x100>;
					#address-cells = <0x1>;
					#size-cells = <0x0>;
					interrupts = <0x4 0x31 0x0 0x1>;
					interrupt-names = "eoc-int-en-set";
					qcom,adc-vdd-reference = <0x753>;
					#io-channel-cells = <0x1>;
					io-channel-ranges;
					pinctrl-names = "default";
					pinctrl-0 = <0x22>;
					phandle = <0x21>;

					ref_gnd@0 {
						reg = <0x0>;
						label = "ref_gnd";
						qcom,pre-scaling = <0x1 0x1>;
					};

					vref_1p25@1 {
						reg = <0x1>;
						label = "vref_1p25";
						qcom,pre-scaling = <0x1 0x1>;
					};

					die_temp@2 {
						reg = <0x6>;
						label = "die_temp";
						qcom,pre-scaling = <0x1 0x1>;
					};

					board_id {
						reg = <0x12>;
						label = "board_id_vdata";
						qcom,ratiometric;
						qcom,pre-scaling = <0x1 0x1>;
					};

					pm8150l_therm1@54 {
						reg = <0x54>;
						label = "pm8150l_therm1";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					vph_pwr@83 {
						reg = <0x83>;
						label = "vph_pwr";
						qcom,pre-scaling = <0x1 0x3>;
					};

					camera_flash_therm@4d {
						reg = <0x4d>;
						label = "camera_flash_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					skin_msm_therm@4e {
						reg = <0x4e>;
						label = "skin_msm_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					pa_therm2@4f {
						reg = <0x4f>;
						label = "pa_therm2";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};
				};

				bcl@3d00 {
					compatible = "qcom,bcl-v5";
					reg = <0x3d00 0x100>;
					interrupts = <0x4 0x3d 0x0 0x0 0x4 0x3d 0x1 0x0 0x4 0x3d 0x2 0x0>;
					interrupt-names = "bcl-lvl0", "bcl-lvl1", "bcl-lvl2";
					#thermal-sensor-cells = <0x1>;
					phandle = <0x27>;
				};

				adc_tm@3500 {
					compatible = "qcom,adc-tm5";
					reg = <0x3500 0x100>;
					interrupts = <0x4 0x35 0x0 0x1>;
					interrupt-names = "thr-int-en";
					#address-cells = <0x1>;
					#size-cells = <0x0>;
					#thermal-sensor-cells = <0x1>;
					io-channels = <0x21 0x4d 0x21 0x4e 0x21 0x4f 0x21 0x54>;
					phandle = <0x25>;

					pm8150l_therm1@54 {
						reg = <0x54>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};

					camera_flash_therm@4d {
						reg = <0x4d>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};

					skin_msm_therm@4e {
						reg = <0x4e>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};

					pa_therm2@4f {
						reg = <0x4f>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};
				};
			};

			qcom,pm8150l@5 {
				compatible = "qcom,spmi-pmic";
				reg = <0x5 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;

				qcom,lcdb@ec00 {
					compatible = "qcom,qpnp-lcdb-regulator";
					reg = <0xec00 0x100>;
					interrupts = <0x5 0xec 0x1 0x1>;
					interrupt-names = "sc-irq";
					qcom,pmic-revid = <0x23>;
					qcom,voltage-step-ramp;
					status = "disabled";
					phandle = <0xb7>;

					ldo {
						label = "ldo";
						regulator-name = "lcdb_ldo";
						regulator-min-microvolt = <0x3d0900>;
						regulator-max-microvolt = <0x5b8d80>;
						phandle = <0xb8>;
					};

					ncp {
						label = "ncp";
						regulator-name = "lcdb_ncp";
						regulator-min-microvolt = <0x3d0900>;
						regulator-max-microvolt = <0x5b8d80>;
						phandle = <0xb9>;
					};

					bst {
						label = "bst";
						regulator-name = "lcdb_bst";
						regulator-min-microvolt = <0x47b760>;
						regulator-max-microvolt = <0x5fbfb8>;
						phandle = <0xba>;
					};
				};

				qcom,leds@d300 {
					compatible = "qcom,qpnp-flash-led-v2";
					status = "okay";
					reg = <0xd300 0x100>;
					label = "flash";
					interrupts = <0x5 0xd3 0x0 0x1 0x5 0xd3 0x3 0x1 0x5 0xd3 0x4 0x1>;
					interrupt-names = "led-fault-irq", "all-ramp-down-done-irq", "all-ramp-up-done-irq";
