	fragment@50 {
		target = <0xffffffff>;

		__overlay__ {

			lpi_pinctrl@33c0000 {
				compatible = "qcom,lpi-pinctrl";
				reg = <0x33c0000 0x0>;
				qcom,slew-reg = <0x355a000 0x0>;
				qcom,num-gpios = <0xe>;
				gpio-controller;
				#gpio-cells = <0x2>;
				qcom,lpi-offset-tbl = <0x0 0x1000 0x2000 0x3000 0x4000 0x5000 0x6000 0x7000 0x8000 0x9000 0xa000 0xb000 0xc000 0xd000>;
				qcom,lpi-slew-offset-tbl = <0x0 0x2 0x4 0x8 0xa 0xc 0x0 0x0 0x0 0x0 0x10 0x12 0x0 0x0>;
				clock-names = "lpass_core_hw_vote", "lpass_audio_hw_vote";
				clocks = <0xffffffff 0x0 0xffffffff 0x0>;
				phandle = <0x64>;

				quat_mi2s_sck {

					quat_mi2s_sck_sleep {
						phandle = <0xee>;

						mux {
							pins = "gpio0";
							function = "func2";
						};

						config {
							pins = "gpio0";
							drive-strength = <0x2>;
							bias-pull-down;
							input-enable;
						};
					};

					quat_mi2s_sck_active {
						phandle = <0xef>;

						mux {
							pins = "gpio0";
							function = "func2";
						};

						config {
							pins = "gpio0";
							drive-strength = <0x8>;
							bias-disable;
							output-high;
						};
					};
				};

				quat_mi2s_ws {

					quat_mi2s_ws_sleep {
						phandle = <0xf0>;

						mux {
							pins = "gpio1";
							function = "func2";
						};

						config {
							pins = "gpio1";
							drive-strength = <0x2>;
							bias-pull-down;
