/dts-v1/;

/ {
	model = "Qualcomm Technologies, Inc. kona MTP";
	compatible = "qcom,kona-mtp", "qcom,kona", "qcom,mtp";
	qcom,board-id = <0x10008 0x0>;
	oplus,dtsi_no = <0x5223>;

	fragment@0 {
		target = <0xffffffff>;

		__overlay__ {
			#address-cells = <0x2>;
			#size-cells = <0x0>;
			interrupt-controller;
			#interrupt-cells = <0x4>;

			qcom,pm8150@0 {
				compatible = "qcom,spmi-pmic";
				reg = <0x0 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;

				qcom,power-on@800 {
					compatible = "qcom,qpnp-power-on";
					reg = <0x800 0x100>;
					interrupts = <0x0 0x8 0x0 0x3 0x0 0x8 0x1 0x3>;
					interrupt-names = "kpdpwr", "resin";
					qcom,pon-dbc-delay = <0x3d09>;
					qcom,kpdpwr-sw-debounce;
					qcom,system-reset;
					qcom,store-hard-reset-reason;
					qcom,pmicwd;

					qcom,pon_1 {
						qcom,pon-type = <0x0>;
						linux,code = <0x74>;
						qcom,pull-up;
					};

					qcom,pon_2 {
						qcom,pon-type = <0x1>;
						linux,code = <0x73>;
						qcom,pull-up;
					};
				};

				qcom,temp-alarm@2400 {
					compatible = "qcom,spmi-temp-alarm";
					reg = <0x2400 0x100>;
					interrupts = <0x0 0x24 0x0 0x3>;
					io-channels = <0x1 0x6>;
					io-channel-names = "thermal";
					#thermal-sensor-cells = <0x0>;
					qcom,temperature-threshold-set = <0x1>;
					phandle = <0x3>;
				};

				clock-controller@5b00 {
					compatible = "qcom,spmi-clkdiv";
					reg = <0x5b00 0x200>;
					#clock-cells = <0x1>;
					qcom,num-clkdivs = <0x2>;
					clock-output-names = "pm8150_div_clk1", "pm8150_div_clk2";
					clocks = <0xffffffff 0x0>;
					clock-names = "xo";
					phandle = <0x79>;
				};

				sdam@b100 {
					compatible = "qcom,spmi-sdam";
					reg = <0xb100 0x100>;
					phandle = <0x10>;
				};

				pinctrl@c000 {
					compatible = "qcom,spmi-gpio";
					reg = <0xc000 0xa00>;
					interrupts = <0x0 0xc0 0x0 0x0 0x0 0xc2 0x0 0x0 0x0 0xc5 0x0 0x0 0x0 0xc6 0x0 0x0 0x0 0xc8 0x0 0x0 0x0 0xc9 0x0 0x0>;
					interrupt-names = "pm8150_gpio1", "pm8150_gpio3", "pm8150_gpio6", "pm8150_gpio7", "pm8150_gpio9", "pm8150_gpio10";
					gpio-controller;
					#gpio-cells = <0x2>;
					qcom,gpios-disallowed = <0x2 0x4 0x5 0x8>;
					phandle = <0xa>;

					key_home {

						key_home_default {
							pins = "gpio1";
							function = "normal";
							input-enable;
							bias-pull-up;
							power-source = <0x0>;
							phandle = <0x7a>;
						};
					};

					key_vol_up {

						key_vol_up_default {
							pins = "gpio7";
							function = "normal";
							input-enable;
							bias-pull-up;
							power-source = <0x1>;
							phandle = <0x6c>;
						};
					};

					key_vol_down {

						key_vol_down_default {
							pins = "gpio6";
							function = "normal";
							input-enable;
							bias-pull-up;
							power-source = <0x1>;
							phandle = <0x6d>;
						};
					};

					key_confirm {

						key_confirm_default {
							pins = "gpio7";
							function = "normal";
							input-enable;
							bias-pull-up;
							power-source = <0x0>;
							phandle = <0x7b>;
						};
					};

					usb2_vbus_boost {

						usb2_vbus_boost_default {
							pins = "gpio9";
							function = "normal";
							output-low;
							power-source = <0x1>;
							phandle = <0x7c>;
						};
					};

					usb2_vbus_det {

						usb2_vbus_det_default {
							pins = "gpio10";
							function = "normal";
							input-enable;
							bias-pull-down;
							power-source = <0x1>;
							phandle = <0x7d>;
						};
					};

					sim2_det_no_pull {
						pins = "gpio1";
						function = "normal";
						input-enable;
						bias-disable;
						phandle = <0x70>;
					};

					sim2_det_pull_high {
						pins = "gpio1";
						function = "normal";
						input-enable;
						bias-pull-up;
						phandle = <0x71>;
					};

					sim2_det_pull_low {
						pins = "gpio1";
						function = "normal";
						input-enable;
						bias-pull-down;
						phandle = <0x72>;
					};

					dischg_enable {
						pins = "gpio10";
						function = "normal";
						bias-disable;
						power-source = <0x0>;
						output-high;
						qcom,drive-strength = <0x3>;
						phandle = <0xb>;
					};

					dischg_disable {
						pins = "gpio10";
						function = "normal";
						bias-disable;
						power-source = <0x0>;
						output-low;
						qcom,drive-strength = <0x3>;
						phandle = <0xc>;
					};

					gpio3_adc {

						gpio3_adc_default {
							pins = "gpio3";
							function = "normal";
							bias-high-impedance;
							phandle = <0x2>;
						};
					};
				};

				qcom,pm8150_rtc {
					compatible = "qcom,pm8941-rtc";
					interrupts = <0x0 0x61 0x1 0x0>;
					phandle = <0x7e>;
				};

				vadc@3100 {
					compatible = "qcom,spmi-adc5";
					reg = <0x3100 0x100>;
					#address-cells = <0x1>;
					#size-cells = <0x0>;
					interrupts = <0x0 0x31 0x0 0x1>;
					interrupt-names = "eoc-int-en-set";
					qcom,adc-vdd-reference = <0x753>;
					#io-channel-cells = <0x1>;
					io-channel-ranges;
					pinctrl-names = "gpio3_adc_default";
					pinctrl-0 = <0x2>;
					phandle = <0x1>;

					ref_gnd@0 {
						reg = <0x0>;
						label = "ref_gnd";
						qcom,pre-scaling = <0x1 0x1>;
					};

					vref_1p25@1 {
						reg = <0x1>;
						label = "vref_1p25";
						qcom,pre-scaling = <0x1 0x1>;
					};

					die_temp@2 {
						reg = <0x6>;
						label = "die_temp";
						qcom,pre-scaling = <0x1 0x1>;
					};

					vph_pwr@83 {
						reg = <0x83>;
						label = "vph_pwr";
						qcom,pre-scaling = <0x1 0x3>;
					};

					vcoin@85 {
						reg = <0x85>;
						label = "vcoin";
						qcom,pre-scaling = <0x1 0x3>;
					};

					xo_therm@4c {
						reg = <0x4c>;
						label = "xo_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					skin_therm@4d {
						reg = <0x4d>;
						label = "skin_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					conn_therm@4e {
						reg = <0x4e>;
						label = "conn_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					board_therm@52 {
						reg = <0x52>;
						label = "board_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};
				};

				adc_tm@3500 {
					compatible = "qcom,adc-tm5";
					reg = <0x3500 0x100>;
					interrupts = <0x0 0x35 0x0 0x1>;
					interrupt-names = "thr-int-en";
					#address-cells = <0x1>;
					#size-cells = <0x0>;
					#thermal-sensor-cells = <0x1>;
					io-channels = <0x1 0x52 0x1 0x4c 0x1 0x4d 0x1 0x4e>;
					phandle = <0x76>;

					board_therm@52 {
						reg = <0x52>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};

					xo_therm@4c {
						reg = <0x4c>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};

					wcn_therm@4d {
						reg = <0x4d>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};

					batt_con_therm@4e {
						reg = <0x4e>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};
				};
			};

			qcom,pm8150@1 {
				compatible = "qcom,spmi-pmic";
				reg = <0x1 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;
			};
		};
	};

	fragment@1 {
		target = <0xffffffff>;

		__overlay__ {

			pm8150_tz {
				polling-delay-passive = <0x64>;
				polling-delay = <0x0>;
				thermal-governor = "step_wise";
				thermal-sensors = <0x3>;
				wake-capable-sensor;
				phandle = <0x7f>;

				trips {

					trip0 {
						temperature = <0x17318>;
						hysteresis = <0x0>;
						type = "passive";
						phandle = <0x80>;
					};

					trip1 {
						temperature = <0x1c138>;
						hysteresis = <0x0>;
						type = "passive";
						phandle = <0x81>;
					};

					trip2 {
						temperature = <0x23668>;
						hysteresis = <0x0>;
						type = "passive";
					};
				};
			};
		};
	};

	fragment@2 {
		target = <0xffffffff>;

		__overlay__ {
			#address-cells = <0x2>;
			#size-cells = <0x0>;
			interrupt-controller;
			#interrupt-cells = <0x4>;

			qcom,pm8150b@2 {
				compatible = "qcom,spmi-pmic";
				reg = <0x2 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;

				qcom,revid@100 {
					compatible = "qcom,qpnp-revid";
					reg = <0x100 0x100>;
					phandle = <0x7>;
				};

				qcom,power-on@800 {
					compatible = "qcom,qpnp-power-on";
					reg = <0x800 0x100>;
				};

				qcom,temp-alarm@2400 {
					compatible = "qcom,spmi-temp-alarm";
					reg = <0x2400 0x100>;
					interrupts = <0x2 0x24 0x0 0x3>;
					io-channels = <0x4 0x6>;
					io-channel-names = "thermal";
					#thermal-sensor-cells = <0x0>;
					qcom,temperature-threshold-set = <0x1>;
					phandle = <0x12>;
				};

				clock-controller@6000 {
					compatible = "qcom,spmi-clkdiv";
					reg = <0x6000 0x100>;
					#clock-cells = <0x1>;
					qcom,num-clkdivs = <0x1>;
					clock-output-names = "pm8150b_div_clk1";
					clocks = <0xffffffff 0x0>;
					clock-names = "xo";
					phandle = <0x82>;
				};

				qcom,pbs@7200 {
					compatible = "qcom,qpnp-pbs";
					reg = <0x7200 0x100>;
					phandle = <0xf>;
				};

				qcom,sdam-qnovo@b000 {
					compatible = "qcom,qpnp-qnovo5";
					reg = <0xb000 0x100>;
					interrupts = <0x2 0xb0 0x1 0x1>;
					interrupt-names = "ptrain-done";
					pinctrl-names = "q_state1", "q_state2";
					pinctrl-0 = <0x5>;
					pinctrl-1 = <0x6>;
					phandle = <0x83>;
				};

				pinctrl@c000 {
					compatible = "qcom,spmi-gpio";
					reg = <0xc000 0xc00>;
					interrupts = <0x2 0xc0 0x0 0x0 0x2 0xc1 0x0 0x0 0x2 0xc4 0x0 0x0 0x2 0xc5 0x0 0x0 0x2 0xc6 0x0 0x0 0x2 0xc7 0x0 0x0 0x2 0xc8 0x0 0x0 0x2 0xc9 0x0 0x0 0x2 0xcb 0x0 0x0>;
					interrupt-names = "pm8150b_gpio1", "pm8150b_gpio2", "pm8150b_gpio5", "pm8150b_gpio6", "pm8150b_gpio7", "pm8150b_gpio8", "pm8150b_gpio9", "pm8150b_gpio10", "pm8150b_gpio12";
					gpio-controller;
					#gpio-cells = <0x2>;
					qcom,gpios-disallowed = <0x3 0x4 0xb>;
					phandle = <0x84>;

					qnovo_fet_ctrl {

						qnovo_fet_ctrl_state1 {
							pins = "gpio8";
							function = "normal";
							input-enable;
							output-disable;
							bias-disable;
							power-source = <0x0>;
							phandle = <0x5>;
						};

						qnovo_fet_ctrl_state2 {
							pins = "gpio8";
							function = "normal";
							input-enable;
							output-disable;
							bias-pull-down;
							power-source = <0x0>;
							phandle = <0x6>;
						};
					};

					smb_stat {

						smb_stat_default {
							pins = "gpio6";
							function = "normal";
							input-enable;
							bias-pull-up;
							qcom,pull-up-strength = <0x0>;
							power-source = <0x0>;
							phandle = <0x85>;
						};
					};

					haptics_boost {

						haptics_boost_default {
							pins = "gpio5";
							function = "normal";
							output-enable;
							input-disable;
							bias-disable;
							qcom,drive-strength = <0x3>;
							power-source = <0x1>;
							phandle = <0x86>;
						};
					};

					colorctrl_sleep_en_default {

						sleep_en_default {
							pins = "gpio5";
							function = "normal";
							bias-disable;
							power-source = <0x0>;
							output-low;
							qcom,drive-strength = <0x3>;
							drive-push-pull;
							phandle = <0x87>;
						};
					};
				};

				qcom,qpnp-smb5 {
					compatible = "qcom,qpnp-smb5";
					#address-cells = <0x1>;
					#size-cells = <0x1>;
					#cooling-cells = <0x2>;
					qcom,pmic-revid = <0x7>;
					qcom,thermal-mitigation = <0x2dc6c0 0x16e360 0xf4240 0x7a120>;
					qcom,chg-term-src = <0x1>;
					qcom,charger-temp-max = <0x320>;
					qcom,smb-temp-max = <0x320>;
					status = "ok";
					dpdm-supply = <0xffffffff>;
					qcom,sec-charger-config = <0x1>;
					qcom,auto-recharge-soc = <0x62>;
					io-channels = <0x4 0x1e 0x4 0x7 0x4 0x99 0x4 0x83 0x4 0x9 0x4 0x4f 0x4 0x4e 0x1 0x52 0x1 0x4e>;
					io-channel-names = "mid_voltage", "usb_in_current", "sbux_res", "vph_voltage", "chg_temp", "usb_temp_adc", "usb_supplementary_temp_adc", "board_therm", "btb_temp_therm";
					qcom,battery-data = <0x8>;
					qcom,step-charging-enable;
					qcom,sw-jeita-enable;
					qcom,wd-bark-time-secs = <0x10>;
					qcom,suspend-input-on-debug-batt;
					qcom,fcc-stepping-enable;
					qcom,smb-internal-pull-kohm = <0x0>;
					qcom,adc-check-pulse;
					qcom,soc-ready-check;
					qcom,usb-icl-ua = <0x1e8480>;
					qcom,fcc-max-ua = <0x2dc6c0>;
					qcom,qc3-disable;
					qcom,hvdcp-disable;
					qcom,smart_charging_screenoff;
					qcom,float-option = <0x1>;
					qcom,oplus-pps-usbpd-detection = <0x9>;
					qcom,input_current_charger_ma = <0x7d0>;
					qcom,pd_input_current_charger_ma = <0x7d0>;
					qcom,qc_input_current_charger_ma = <0x7d0>;
					qcom,input_current_usb_ma = <0x1f4>;
					qcom,input_current_cdp_ma = <0x5dc>;
					qcom,input_current_led_ma = <0x4b0>;
					qcom,input_current_led_ma_high = <0x5dc>;
					qcom,input_current_led_ma_warm = <0x708>;
					qcom,input_current_led_ma_normal = <0x7d0>;
					qcom,led_warm_bat_decidegc = <0x15e>;
					qcom,led_high_bat_decidegc = <0x172>;
					qcom,input_current_camera_ma = <0x4b0>;
					qcom,input_current_vooc_led_ma_high = <0x4b0>;
					qcom,input_current_vooc_led_ma_warm = <0x708>;
					qcom,input_current_vooc_led_ma_normal = <0xe10>;
					qcom,input_current_vooc_ma_normal = <0xe10>;
					qcom,vooc_temp_bat_normal_decidegc = <0x15e>;
					qcom,input_current_vooc_ma_warm = <0xc80>;
					qcom,vooc_temp_bat_warm_decidegc = <0x172>;
					qcom,input_current_vooc_ma_high = <0x898>;
					qcom,vooc_temp_bat_hot_decidegc = <0x1b8>;
					qcom,charger_current_vooc_ma_normal = <0x708>;
					qcom,chg_ctrl_by_calling;
					qcom,input_current_calling_ma = <0x5dc>;
					qcom,overtemp_bat_decidegc = <0x15e>;
					qcom,iterm_disabled = <0x0>;
					qcom,iterm_ma = <0x1a2>;
					qcom,recharge-mv = <0x64>;
					qcom,batt_capacity_mah = <0x20a8>;
					qcom,removed_bat_decidegc = <0xbe>;
					qcom,cold_bat_decidegc = <0x64>;
					qcom,temp_cold_vfloat_mv = <0x1153>;
					qcom,temp_cold_fastchg_current_ma = <0x640>;
					qcom,temp_cold_fastchg_current_ma_high = <0x640>;
					qcom,temp_cold_fastchg_current_ma_low = <0x4b0>;
					qcom,pd_temp_cold_fastchg_current_ma_high = <0x640>;
					qcom,pd_temp_cold_fastchg_current_ma_low = <0x4b0>;
					qcom,qc_temp_cold_fastchg_current_ma_high = <0x640>;
					qcom,qc_temp_cold_fastchg_current_ma_low = <0x4b0>;
					qcom,little_cold_bat_decidegc = <0x0>;
					qcom,temp_little_cold_vfloat_mv = <0x1153>;
					qcom,temp_little_cold_fastchg_current_ma_high = <0x898>;
					qcom,temp_little_cold_fastchg_current_ma_low = <0x7d0>;
					qcom,temp_little_cold_fastchg_current_ma = <0x898>;
					qcom,pd_temp_little_cold_fastchg_current_ma_high = <0xbb8>;
					qcom,pd_temp_little_cold_fastchg_current_ma_low = <0x7d0>;
					qcom,qc_temp_little_cold_fastchg_current_ma_high = <0xbb8>;
					qcom,qc_temp_little_cold_fastchg_current_ma_low = <0x7d0>;
					qcom,cool_bat_decidegc = <0x32>;
					qcom,temp_cool_vfloat_mv = <0x1153>;
					qcom,temp_cool_fastchg_current_ma_high = <0x898>;
					qcom,temp_cool_fastchg_current_ma_low = <0x898>;
					qcom,pd_temp_cool_fastchg_current_ma_high = <0xbb8>;
					qcom,pd_temp_cool_fastchg_current_ma_low = <0xbb8>;
					qcom,qc_temp_cool_fastchg_current_ma_high = <0xbb8>;
					qcom,qc_temp_cool_fastchg_current_ma_low = <0xbb8>;
					qcom,little_cool_bat_decidegc = <0x78>;
					qcom,temp_little_cool_vfloat_mv = <0x1153>;
					qcom,temp_little_cool_fastchg_current_ma = <0x898>;
					qcom,pd_temp_little_cool_fastchg_current_ma = <0xbb8>;
					qcom,qc_temp_little_cool_fastchg_current_ma = <0xbb8>;
					qcom,normal_bat_decidegc = <0xa0>;
					qcom,temp_normal_fastchg_current_ma = <0x898>;
					qcom,temp_normal_vfloat_mv = <0x1153>;
					qcom,pd_temp_normal_fastchg_current_ma = <0xbb8>;
					qcom,qc_temp_normal_fastchg_current_ma = <0xbb8>;
					qcom,warm_bat_decidegc = <0x1c2>;
					qcom,temp_warm_vfloat_mv = <0x1022>;
					qcom,temp_warm_fastchg_current_ma = <0x7d0>;
					qcom,pd_temp_warm_fastchg_current_ma = <0x3e8>;
					qcom,qc_temp_warm_fastchg_current_ma = <0x3e8>;
					qcom,temp_warm_fastchg_current_ma_led_on = <0x3e8>;
					qcom,hot_bat_decidegc = <0x212>;
					qcom,non_standard_vfloat_mv = <0xf8c>;
					qcom,non_standard_fastchg_current_ma = <0x200>;
					qcom,short_c_bat_cv_mv = <0x10ea>;
					qcom,short_c_bat_vfloat_mv = <0xed8>;
					qcom,short_c_bat_fastchg_current_ma = <0x200>;
					qcom,cold_vfloat_sw_limit = <0x1121>;
					qcom,little_cold_vfloat_sw_limit = <0x1121>;
					qcom,cool_vfloat_sw_limit = <0x1121>;
