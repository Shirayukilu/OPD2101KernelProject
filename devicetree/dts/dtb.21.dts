	fragment@3 {
		target = <0xffffffff>;

		__overlay__ {

			pm8150b_tz {
				polling-delay-passive = <0x64>;
				polling-delay = <0x0>;
				thermal-governor = "step_wise";
				thermal-sensors = <0x12>;
				wake-capable-sensor;
				phandle = <0x8b>;

				trips {

					trip0 {
						temperature = <0x17318>;
						hysteresis = <0x0>;
						type = "passive";
						phandle = <0x8c>;
					};

					trip1 {
						temperature = <0x1c138>;
						hysteresis = <0x0>;
						type = "passive";
						phandle = <0x8d>;
					};

					trip2 {
						temperature = <0x23668>;
						hysteresis = <0x0>;
