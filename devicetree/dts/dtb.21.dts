	fragment@59 {
		target = <0xffffffff>;

		__overlay__ {
			status = "ok";
		};
	};

	fragment@60 {
		target = <0xffffffff>;

		__overlay__ {
			status = "ok";
		};
	};

	fragment@61 {
		target = <0xffffffff>;

		__overlay__ {
			status = "ok";

			pencil-wireless-charger@3b {
				status = "ok";
				compatible = "oplus,pencil-wireless-charger";
				reg = <0x3b 0x0>;
				pinctrl-names = "idt_int_active", "idt_int_sleep", "idt_int_default", "vbat_en_active", "vbat_en_sleep", "vbat_en_default", "booster_en_active", "booster_en_sleep", "booster_en_default";
				pinctrl-0 = <0xffffffff>;
				pinctrl-1 = <0xffffffff>;
				pinctrl-2 = <0xffffffff>;
				pinctrl-3 = <0xffffffff>;
				pinctrl-4 = <0xffffffff>;
				pinctrl-5 = <0xffffffff>;
				pinctrl-6 = <0xffffffff>;
				pinctrl-7 = <0xffffffff>;
				pinctrl-8 = <0xffffffff>;
				qcom,idt_int-gpio = <0xffffffff 0x1f 0x0>;
				qcom,vbat_en-gpio = <0xffffffff 0x21 0x0>;
				qcom,booster_en-gpio = <0xffffffff 0x1e 0x0>;
				qcom,ocp_threshold = <0x1f4>;
				qcom,ovp_threshold = <0x2ee0>;
				qcom,lvp_threshold = <0xfa0>;
				qcom,pcop_threshold1 = <0x2bc>;
				qcom,pcop_threshold2 = <0x1f4>;
				qcom,fod_threshold = <0x190>;
				rx,soc_threshold = <0x5a>;
				unhealth_memory_handle_support;
			};
		};
	};

	fragment@62 {
		target = <0xffffffff>;

		__overlay__ {
			status = "disabled";
			#address-cells = <0x1>;
			#size-cells = <0x0>;

			nq@28 {
				compatible = "qcom,nq-nci";
				reg = <0x28>;
				qcom,nq-irq = <0xffffffff 0x6f 0x0>;
				qcom,nq-ven = <0xffffffff 0x53 0x0>;
				qcom,nq-firm = <0xffffffff 0x6e 0x0>;
				qcom,nq-clkreq = <0xffffffff 0x7 0x0>;
				interrupt-parent = <0xffffffff>;
				interrupts = <0x6f 0x0>;
				interrupt-names = "nfc_irq";
				pinctrl-names = "nfc_active", "nfc_suspend";
				pinctrl-0 = <0xffffffff 0xffffffff 0xffffffff>;
				pinctrl-1 = <0xffffffff 0xffffffff 0xffffffff>;
			};
		};
	};

	fragment@63 {
		target = <0xffffffff>;

		__overlay__ {
			status = "ok";
			qcom,clk-freq-out = <0x61a80>;

			pixelworks@26 {
				status = "ok";
				compatible = "pixelworks,iris5";
				reg = <0x26>;
			};
		};
	};

	fragment@64 {
		target = <0xffffffff>;

		__overlay__ {
			compatible = "qcom,ufs-phy-qmp-v4";
			vdda-phy-supply = <0xffffffff>;
			vdda-phy-always-on;
			vdda-pll-supply = <0xffffffff>;
			vdda-phy-max-microamp = <0x15f2c>;
			vdda-pll-max-microamp = <0x4970>;
			status = "ok";
		};
	};

	fragment@65 {
		target = <0xffffffff>;

		__overlay__ {
			vdd-hba-supply = <0xffffffff>;
			vdd-hba-fixed-regulator;
			vcc-supply = <0xffffffff>;
			vcc-voltage-level = <0x263540 0x2d0370>;
			vcc-low-voltage-sup;
			vccq-supply = <0xffffffff>;
			vccq2-supply = <0xffffffff>;
			vcc-max-microamp = <0xc3500>;
			vccq-max-microamp = <0xc3500>;
			vccq2-max-microamp = <0xc3500>;
			qcom,vddp-ref-clk-supply = <0xffffffff>;
			qcom,vddp-ref-clk-max-microamp = <0x64>;
			qcom,vccq-parent-supply = <0xffffffff>;
			qcom,vccq-parent-max-microamp = <0x33450>;
			status = "ok";
		};
	};

	fragment@66 {
		target = <0xffffffff>;

		__overlay__ {

			esim_gpio {
				phandle = <0x6e>;

				mux {
					pins = "gpio67";
					function = "gpio";
				};

				config {
					pins = "gpio67";
					bias-disable;
					drive-strength = <0x2>;
					output-low;
				};
			};

			esim_det_gpio {
				phandle = <0x6f>;

				mux {
					pins = "gpio70";
					function = "gpio";
				};

				config {
					pins = "gpio70";
					bias-disable;
					drive-strength = <0x2>;
					output-high;
				};
			};
		};
	};

	fragment@67 {
		target = <0xffffffff>;

		__overlay__ {

			nfc_chipset {
				compatible = "oplus-nfc-chipset";
				chipset-21027 = "SN100T";
				chipset-20351 = "SN100T";
				chipset-20163 = "SN100T";
			};

			gpio_keys {
				compatible = "gpio-keys";
				label = "gpio-keys";
				pinctrl-names = "default";
				pinctrl-0 = <0x6c 0x6d>;

				vol_up {
					label = "volume_up";
					gpios = <0xa 0x7 0x1>;
					linux,input-type = <0x1>;
					linux,code = <0x73>;
					gpio-key,wakeup;
					debounce-interval = <0xf>;
					linux,can-disable;
				};

				vol_down {
					label = "volume_down";
					gpios = <0xa 0x6 0x1>;
					linux,input-type = <0x1>;
					linux,code = <0x72>;
					gpio-key,wakeup;
					debounce-interval = <0xf>;
					linux,can-disable;
