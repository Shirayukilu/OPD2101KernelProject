				};
			};

			pm8150b-vbat-lvl0 {
				polling-delay-passive = <0x0>;
				polling-delay = <0x0>;
				thermal-governor = "low_limits_cap";
				thermal-sensors = <0x13 0x2>;
				tracks-low;
				wake-capable-sensor;

				trips {

					vbat-lvl0 {
						temperature = <0xbb8>;
						hysteresis = <0xc8>;
						type = "passive";
						phandle = <0x90>;
					};
				};
			};

			pm8150b-vbat-lvl1 {
				polling-delay-passive = <0x0>;
				polling-delay = <0x0>;
				thermal-governor = "low_limits_cap";
				thermal-sensors = <0x13 0x3>;
				tracks-low;
				wake-capable-sensor;

				trips {

					vbat-lvl1 {
						temperature = <0xaf0>;
						hysteresis = <0xc8>;
						type = "passive";
						phandle = <0x91>;
					};
				};
			};

			pm8150b-vbat-lvl2 {
				polling-delay-passive = <0x0>;
				polling-delay = <0x0>;
				thermal-governor = "low_limits_cap";
				thermal-sensors = <0x13 0x4>;
				tracks-low;
				wake-capable-sensor;

				trips {

					vbat-lvl2 {
						temperature = <0xa28>;
						hysteresis = <0xc8>;
						type = "passive";
						phandle = <0x92>;
					};
				};
			};

			pm8150b-bcl-lvl0 {
				polling-delay-passive = <0x64>;
				polling-delay = <0x0>;
				thermal-governor = "step_wise";
				thermal-sensors = <0x13 0x5>;
				wake-capable-sensor;

				trips {

					b-bcl-lvl0 {
						temperature = <0x1>;
						hysteresis = <0x1>;
						type = "passive";
						phandle = <0x66>;
					};
				};
			};

			pm8150b-bcl-lvl1 {
				polling-delay-passive = <0x64>;
				polling-delay = <0x0>;
				thermal-governor = "step_wise";
				thermal-sensors = <0x13 0x6>;
				wake-capable-sensor;

				trips {

					b-bcl-lvl1 {
						temperature = <0x1>;
						hysteresis = <0x1>;
						type = "passive";
						phandle = <0x67>;
					};
				};
			};

			pm8150b-bcl-lvl2 {
				polling-delay-passive = <0x64>;
				polling-delay = <0x0>;
				thermal-governor = "step_wise";
				thermal-sensors = <0x13 0x7>;
				wake-capable-sensor;

				trips {

					b-bcl-lvl2 {
						temperature = <0x1>;
						hysteresis = <0x1>;
						type = "passive";
						phandle = <0x68>;
					};
				};
			};

			soc {
				polling-delay-passive = <0x64>;
				polling-delay = <0x0>;
				thermal-governor = "low_limits_cap";
				thermal-sensors = <0x14>;
				tracks-low;
				wake-capable-sensor;

				trips {

					soc-trip {
						temperature = <0xa>;
						hysteresis = <0x0>;
						type = "passive";
						phandle = <0x93>;
					};
				};
			};
		};
	};

	fragment@4 {
		target = <0xffffffff>;

		__overlay__ {
			#address-cells = <0x2>;
			#size-cells = <0x0>;
			interrupt-controller;
			#interrupt-cells = <0x4>;

			qcom,pm8150l@4 {
				compatible = "qcom,spmi-pmic";
				reg = <0x4 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;

				qcom,revid@100 {
					compatible = "qcom,qpnp-revid";
					reg = <0x100 0x100>;
					phandle = <0x16>;
				};

				qcom,power-on@800 {
					compatible = "qcom,qpnp-power-on";
					reg = <0x800 0x100>;
				};

				qcom,temp-alarm@2400 {
					compatible = "qcom,spmi-temp-alarm";
					reg = <0x2400 0x100>;
					interrupts = <0x4 0x24 0x0 0x3>;
					io-channels = <0x15 0x6>;
					io-channel-names = "thermal";
					#thermal-sensor-cells = <0x0>;
					qcom,temperature-threshold-set = <0x1>;
					phandle = <0x18>;
				};

				clock-controller@5b00 {
					compatible = "qcom,spmi-clkdiv";
					reg = <0x5b00 0x100>;
					#clock-cells = <0x1>;
					qcom,num-clkdivs = <0x1>;
					clock-output-names = "pm8150l_div_clk1";
					clocks = <0xffffffff 0x0>;
					clock-names = "xo";
					phandle = <0x94>;
				};

				pinctrl@c000 {
					compatible = "qcom,spmi-gpio";
					reg = <0xc000 0xc00>;
					interrupts = <0x4 0xc0 0x0 0x0 0x4 0xc2 0x0 0x0 0x4 0xc3 0x0 0x0 0x4 0xc4 0x0 0x0 0x4 0xc5 0x0 0x0 0x4 0xc6 0x0 0x0 0x4 0xc7 0x0 0x0 0x4 0xc8 0x0 0x0 0x4 0xc9 0x0 0x0 0x4 0xca 0x0 0x0>;
					interrupt-names = "pm8150l_gpio1", "pm8150l_gpio3", "pm8150l_gpio4", "pm8150l_gpio5", "pm8150l_gpio6", "pm8150l_gpio7", "pm8150l_gpio8", "pm8150l_gpio9", "pm8150l_gpio10", "pm8150l_gpio11";
					gpio-controller;
					#gpio-cells = <0x2>;
					qcom,gpios-disallowed = <0x2 0xc>;
					phandle = <0x95>;

					colorctrl_enable_fade_default {

						enable_fade_default {
							pins = "gpio9";
							function = "normal";
							bias-disable;
							power-source = <0x0>;
							output-low;
							qcom,drive-strength = <0x3>;
							drive-push-pull;
							phandle = <0x96>;
						};
					};

					colorctrl_enable_vm_default {

						enable_vm_default {
							pins = "gpio9";
							function = "normal";
							bias-disable;
							power-source = <0x0>;
							output-low;
							qcom,drive-strength = <0x3>;
							drive-push-pull;
							phandle = <0x97>;
						};
					};

					colorctrl_si_in_1_default {

						si_in_1_default {
							pins = "gpio8";
							function = "normal";
							bias-disable;
							power-source = <0x0>;
							output-low;
							qcom,drive-strength = <0x3>;
							drive-push-pull;
							phandle = <0x98>;
						};
					};

					colorctrl_si_in_2_default {

						si_in_2_default {
							pins = "gpio11";
							function = "normal";
							bias-disable;
							power-source = <0x0>;
							output-low;
							qcom,drive-strength = <0x3>;
							drive-push-pull;
							phandle = <0x99>;
						};
					};

					colorctrl_adc {

						colorctrl_adc_default {
							pins = "gpio7";
							function = "normal";
							bias-high-impedance;
							phandle = <0x9a>;
						};
					};
				};

				vadc@3100 {
					compatible = "qcom,spmi-adc5";
					reg = <0x3100 0x100>;
					#address-cells = <0x1>;
					#size-cells = <0x0>;
					interrupts = <0x4 0x31 0x0 0x1>;
					interrupt-names = "eoc-int-en-set";
					qcom,adc-vdd-reference = <0x753>;
					#io-channel-cells = <0x1>;
					io-channel-ranges;
					phandle = <0x15>;

					ref_gnd@0 {
						reg = <0x0>;
						label = "ref_gnd";
						qcom,pre-scaling = <0x1 0x1>;
					};

					vref_1p25@1 {
						reg = <0x1>;
						label = "vref_1p25";
						qcom,pre-scaling = <0x1 0x1>;
					};

					die_temp@2 {
						reg = <0x6>;
						label = "die_temp";
						qcom,pre-scaling = <0x1 0x1>;
					};

					board_id {
						reg = <0x12>;
						label = "board_id_vdata";
						qcom,ratiometric;
						qcom,pre-scaling = <0x1 0x1>;
					};

					vph_pwr@83 {
						reg = <0x83>;
						label = "vph_pwr";
						qcom,pre-scaling = <0x1 0x3>;
					};

					cam_fl_therm@4d {
						reg = <0x4d>;
						label = "cam_fl_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					sdm_skin_therm@4e {
						reg = <0x4e>;
						label = "sdm_skin_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					chg_fast_therm@4f {
						reg = <0x4f>;
						label = "chg_fast_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x1 0x1>;
					};

					colorctrl_voltage_adc {
						reg = <0x94>;
						label = "colorctrl_voltage_adc";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,avg-samples = <0x2>;
						qcom,pre-scaling = <0x1 0x3>;
					};
				};

				bcl@3d00 {
					compatible = "qcom,bcl-v5";
					reg = <0x3d00 0x100>;
					interrupts = <0x4 0x3d 0x0 0x0 0x4 0x3d 0x1 0x0 0x4 0x3d 0x2 0x0>;
					interrupt-names = "bcl-lvl0", "bcl-lvl1", "bcl-lvl2";
					#thermal-sensor-cells = <0x1>;
					phandle = <0x19>;
				};

				adc_tm@3500 {
					compatible = "qcom,adc-tm5";
					reg = <0x3500 0x100>;
					interrupts = <0x4 0x35 0x0 0x1>;
					interrupt-names = "thr-int-en";
					#address-cells = <0x1>;
					#size-cells = <0x0>;
					#thermal-sensor-cells = <0x1>;
					io-channels = <0x15 0x4d 0x15 0x4e 0x15 0x4f>;
					phandle = <0x77>;

					cam_fl_therm@4d {
						reg = <0x4d>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};

					sdm_skin_therm@4e {
						reg = <0x4e>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};

					chg_fast_therm@4f {
						reg = <0x4f>;
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
					};
				};
			};

			qcom,pm8150l@5 {
				compatible = "qcom,spmi-pmic";
				reg = <0x5 0x0>;
				#address-cells = <0x2>;
				#size-cells = <0x0>;

				qcom,lcdb@ec00 {
					compatible = "qcom,qpnp-lcdb-regulator";
					reg = <0xec00 0x100>;
					interrupts = <0x5 0xec 0x1 0x1>;
					interrupt-names = "sc-irq";
					qcom,pmic-revid = <0x16>;
					qcom,voltage-step-ramp;
					status = "disabled";
					phandle = <0x9b>;

					ldo {
						label = "ldo";
						regulator-name = "lcdb_ldo";
						regulator-min-microvolt = <0x3d0900>;
						regulator-max-microvolt = <0x5b8d80>;
						phandle = <0x9c>;
					};

					ncp {
						label = "ncp";
						regulator-name = "lcdb_ncp";
						regulator-min-microvolt = <0x3d0900>;
						regulator-max-microvolt = <0x5b8d80>;
						phandle = <0x9d>;
					};

					bst {
						label = "bst";
						regulator-name = "lcdb_bst";
						regulator-min-microvolt = <0x47b760>;
						regulator-max-microvolt = <0x5fbfb8>;
						phandle = <0x9e>;
					};
				};

				qcom,leds@d300 {
					compatible = "qcom,qpnp-flash-led-v2";
					status = "okay";
					reg = <0xd300 0x100>;
					label = "flash";
					interrupts = <0x5 0xd3 0x0 0x1 0x5 0xd3 0x3 0x1 0x5 0xd3 0x4 0x1>;
					interrupt-names = "led-fault-irq", "all-ramp-down-done-irq", "all-ramp-up-done-irq";
					qcom,hdrm-auto-mode;
					qcom,short-circuit-det;
					qcom,open-circuit-det;
					qcom,vph-droop-det;
					qcom,thermal-derate-en;
					qcom,thermal-derate-current = <0xc8 0x1f4 0x3e8>;
					qcom,isc-delay = <0xc0>;
					qcom,pmic-revid = <0x16>;
					phandle = <0x9f>;

					qcom,flash_0 {
						label = "flash";
						qcom,led-name = "led:flash_0";
						qcom,max-current = <0x5dc>;
						qcom,default-led-trigger = "flash0_trigger";
						qcom,id = <0x0>;
						qcom,current-ma = <0x3e8>;
						qcom,duration-ms = <0x500>;
						qcom,ires-ua = <0x1388>;
						qcom,hdrm-voltage-mv = <0x145>;
						qcom,hdrm-vol-hi-lo-win-mv = <0x64>;
						phandle = <0x26>;
					};

					qcom,flash_1 {
						label = "flash";
						qcom,led-name = "led:flash_1";
						qcom,max-current = <0x5dc>;
						qcom,default-led-trigger = "flash1_trigger";
						qcom,id = <0x1>;
						qcom,current-ma = <0x3e8>;
						qcom,duration-ms = <0x500>;
						qcom,ires-ua = <0x1388>;
						qcom,hdrm-voltage-mv = <0x145>;
						qcom,hdrm-vol-hi-lo-win-mv = <0x64>;
						phandle = <0x27>;
					};

					qcom,flash_2 {
						label = "flash";
						qcom,led-name = "led:flash_2";
						qcom,max-current = <0x2ee>;
						qcom,default-led-trigger = "flash2_trigger";
						qcom,id = <0x2>;
						qcom,current-ma = <0x1f4>;
						qcom,duration-ms = <0x500>;
						qcom,ires-ua = <0x1388>;
						qcom,hdrm-voltage-mv = <0x145>;
						qcom,hdrm-vol-hi-lo-win-mv = <0x64>;
						status = "disabled";
						phandle = <0xa0>;
					};

					qcom,torch_0 {
						label = "torch";
						qcom,led-name = "led:torch_0";
						qcom,max-current = <0x1f4>;
						qcom,default-led-trigger = "torch0_trigger";
						qcom,id = <0x0>;
						qcom,current-ma = <0x12c>;
						qcom,ires-ua = <0x1d4c>;
						qcom,hdrm-voltage-mv = <0x145>;
						qcom,hdrm-vol-hi-lo-win-mv = <0x64>;
						phandle = <0x28>;
					};

					qcom,torch_1 {
						label = "torch";
						qcom,led-name = "led:torch_1";
						qcom,max-current = <0x1f4>;
						qcom,default-led-trigger = "torch1_trigger";
						qcom,id = <0x1>;
						qcom,current-ma = <0x12c>;
						qcom,ires-ua = <0x1d4c>;
						qcom,hdrm-voltage-mv = <0x145>;
						qcom,hdrm-vol-hi-lo-win-mv = <0x64>;
						phandle = <0x29>;
					};

					qcom,torch_2 {
						label = "torch";
						qcom,led-name = "led:torch_2";
						qcom,max-current = <0x1f4>;
						qcom,default-led-trigger = "torch2_trigger";
						qcom,id = <0x2>;
						qcom,current-ma = <0x12c>;
						qcom,ires-ua = <0x1388>;
						qcom,hdrm-voltage-mv = <0x145>;
						qcom,hdrm-vol-hi-lo-win-mv = <0x64>;
						status = "disabled";
						phandle = <0xa1>;
					};

					qcom,led_switch_0 {
						label = "switch";
						qcom,led-name = "led:switch_0";
						qcom,led-mask = <0x1>;
						qcom,default-led-trigger = "switch0_trigger";
						phandle = <0xa2>;
					};

					qcom,led_switch_1 {
						label = "switch";
						qcom,led-name = "led:switch_1";
						qcom,led-mask = <0x2>;
						qcom,default-led-trigger = "switch1_trigger";
						phandle = <0xa3>;
					};

					qcom,led_switch_2 {
						label = "switch";
						qcom,led-name = "led:switch_2";
						qcom,led-mask = <0x3>;
						qcom,default-led-trigger = "switch2_trigger";
						phandle = <0x2a>;
					};

					qcom,led_switch_3 {
						label = "switch";
						qcom,led-name = "led:switch_3";
						qcom,led-mask = <0x4>;
						qcom,default-led-trigger = "switch3_trigger";
						phandle = <0xa4>;
					};
				};

				qcom,wled@d800 {
					compatible = "qcom,pm8150l-spmi-wled";
					reg = <0xd800 0x100 0xd900 0x100>;
					reg-names = "wled-ctrl-base", "wled-sink-base";
					label = "backlight";
					interrupts = <0x5 0xd8 0x1 0x1 0x5 0xd8 0x4 0x3 0x5 0xd8 0x5 0x3>;
					interrupt-names = "ovp-irq", "pre-flash-irq", "flash-irq";
					qcom,pmic-revid = <0x16>;
					qcom,auto-calibration;
					status = "disabled";
					phandle = <0xa5>;

					qcom,wled-flash {
						label = "flash";
						qcom,default-led-trigger = "wled_flash";
						phandle = <0xa6>;
					};

					qcom,wled-torch {
						label = "torch";
						qcom,default-led-trigger = "wled_torch";
						qcom,wled-torch-timer = <0x4b0>;
						phandle = <0xa7>;
					};

					qcom,wled-switch {
						label = "switch";
						qcom,default-led-trigger = "wled_switch";
						phandle = <0xa8>;
					};
				};

				qcom,pwms@b100 {
					compatible = "qcom,pwm-lpg";
					reg = <0xb100 0x300 0xb000 0x100>;
					reg-names = "lpg-base", "lut-base";
					#pwm-cells = <0x2>;
					qcom,num-lpg-channels = <0x3>;
					qcom,lut-patterns = <0x0 0xa 0x14 0x1e 0x28 0x32 0x3c 0x46 0x50 0x5a 0x64 0x5a 0x50 0x46 0x3c 0x32 0x28 0x1e 0x14 0xa 0x0>;
					phandle = <0x17>;

					lpg1 {
						qcom,lpg-chan-id = <0x1>;
						qcom,ramp-step-ms = <0x64>;
						qcom,ramp-pause-hi-count = <0x2>;
						qcom,ramp-pause-lo-count = <0x2>;
						qcom,ramp-low-index = <0x0>;
						qcom,ramp-high-index = <0x14>;
						qcom,ramp-from-low-to-high;
						qcom,ramp-pattern-repeat;
					};

					lpg2 {
						qcom,lpg-chan-id = <0x2>;
						qcom,ramp-step-ms = <0x64>;
						qcom,ramp-pause-hi-count = <0x2>;
						qcom,ramp-pause-lo-count = <0x2>;
						qcom,ramp-low-index = <0x0>;
						qcom,ramp-high-index = <0x14>;
						qcom,ramp-from-low-to-high;
						qcom,ramp-pattern-repeat;
					};

					lpg3 {
						qcom,lpg-chan-id = <0x3>;
						qcom,ramp-step-ms = <0x64>;
						qcom,ramp-pause-hi-count = <0x2>;
						qcom,ramp-pause-lo-count = <0x2>;
						qcom,ramp-low-index = <0x0>;
						qcom,ramp-high-index = <0x14>;
						qcom,ramp-from-low-to-high;
						qcom,ramp-pattern-repeat;
					};
				};

				qcom,pwms@bc00 {
					compatible = "qcom,pwm-lpg";
					reg = <0xbc00 0x200>;
					reg-names = "lpg-base";
					#pwm-cells = <0x2>;
					qcom,num-lpg-channels = <0x2>;
					phandle = <0xa9>;
				};

				qcom,leds@d000 {
					compatible = "qcom,tri-led";
					reg = <0xd000 0x100>;
					phandle = <0xaa>;

					red {
						label = "red";
						pwms = <0x17 0x0 0xf4240>;
						led-sources = <0x0>;
						linux,default-trigger = "timer";
					};

					green {
						label = "green";
						pwms = <0x17 0x1 0xf4240>;
						led-sources = <0x1>;
						linux,default-trigger = "timer";
					};

					blue {
						label = "blue";
						pwms = <0x17 0x2 0xf4240>;
						led-sources = <0x2>;
						linux,default-trigger = "timer";
					};
				};

				qcom,amoled {
					compatible = "qcom,qpnp-amoled-regulator";
					#address-cells = <0x1>;
					#size-cells = <0x1>;
					status = "ok";
					phandle = <0xab>;

					oledb@e000 {
						reg = <0xe000 0x100>;
						reg-names = "oledb_base";
						regulator-name = "oledb";
						regulator-min-microvolt = <0x4b2648>;
						regulator-max-microvolt = <0x7b98a0>;
						qcom,swire-control;
						phandle = <0xac>;
					};

					ab@de00 {
						reg = <0xde00 0x100>;
						reg-names = "ab_base";
						regulator-name = "ab";
						regulator-min-microvolt = <0x4630c0>;
						regulator-max-microvolt = <0x5d1420>;
						qcom,swire-control;
						phandle = <0xad>;
					};

					ibb@dc00 {
						reg = <0xdc00 0x100>;
						reg-names = "ibb_base";
						regulator-name = "ibb";
						regulator-min-microvolt = <0xc3500>;
						regulator-max-microvolt = <0x5265c0>;
						qcom,swire-control;
						phandle = <0xae>;
					};
				};
			};
		};
	};

	fragment@5 {
		target = <0xffffffff>;

		__overlay__ {

			pm8150l_tz {
				polling-delay-passive = <0x64>;
				polling-delay = <0x0>;
